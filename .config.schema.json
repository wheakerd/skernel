{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Project Configuration",
    "type": "object",
    "properties": {
        "name": {
            "type": "string"
        },
        "debug": {
            "type": "boolean"
        },
        "database": {
            "type": "object",
            "properties": {
                "host": {
                    "type": "string"
                },
                "port": {
                    "type": "integer"
                }
            },
            "required": [
                "host",
                "port"
            ]
        }
    },
    "required": [
        "name",
        "debug"
    ]
}